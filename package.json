{
  "name": "@redbark/actual-sync",
  "version": "0.1.0",
  "description": "Sync bank transactions from Redbark to Actual Budget",
  "type": "module",
  "main": "dist/main.cjs",
  "bin": {
    "redbark-actual-sync": "dist/main.cjs"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@actual-app/api": "^26.5.2",
    "pino": "^9.14.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsup": "^8.5.1",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/redbark-co/actual-sync"
  },
  "keywords": [
    "actual-budget",
    "redbark",
    "bank-sync",
    "transactions",
    "personal-finance"
  ]

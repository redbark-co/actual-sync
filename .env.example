# Redbark API
REDBARK_API_KEY=rbk_live_your_key_here
REDBARK_API_URL=https://app.redbark.co

# Actual Budget
ACTUAL_SERVER_URL=http://localhost:5006
ACTUAL_PASSWORD=your-actual-password
ACTUAL_BUDGET_ID=your-budget-sync-id
# ACTUAL_ENCRYPTION_PASSWORD=optional-e2e-encryption-password
# ACTUAL_DATA_DIR=./data

# Account Mapping (redbark_account_id:actual_account_id, comma-separated)
ACCOUNT_MAPPING=redbark-acc-id:actual-acc-id

# Sync Options
# SYNC_DAYS=30
# LOG_LEVEL=info
# DRY_RUN=false
